{
  "name": "framegen",
  "version": "1.0.0",
  "description": "Chat → Blueprint → Video — personal AI video production tool",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "concurrently --names \"API,UI\" --prefix-colors \"cyan,magenta\" \"npm run server\" \"npm run client\"",
    "server": "node --watch server/index.js",
    "client": "cd client && npm run dev",
    "debug": "node scripts/auto-debug.js",
    "build": "cd client && npm install && npm run build",
    "start": "NODE_ENV=production node server/index.js",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^7.1.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.20.0",
    "uuid": "^10.0.0",
    "youtube-dl-exec": "^3.1.4",
    "yt-search": "^2.13.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
